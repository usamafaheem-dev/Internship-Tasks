PORT=5000
# Local MongoDB:
# MONGO_URI=mongodb://127.0.0.1:27017/crud_backend

# MongoDB Atlas (replace username/password):
MONGO_URI=mongodb+srv://username:password@cluster0.zobgan0.mongodb.net/crud_backend?retryWrites=true&w=majority&appName=Cluster0

# Optional: if DNS SRV lookup fails in your network
DNS_SERVERS=8.8.8.8,1.1.1.1
